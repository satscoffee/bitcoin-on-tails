#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2026 Satoshi Coffee Co. — see LICENSE.

###############################################################################
# bot-menu — Bitcoin on Tails control panel.
#
# Phase 2c skeleton: Status tab + About tab.
# Future phases add Bitcoin / Sparrow / Storage / Network / Backup tabs
# and wire up --check / --update / --uninstall flows on the installer scripts.
#
# Requires `yad`. The BoT installer ships a verified yad .deb in
# .local/share/bot/debs/ and installs it on first run.
###############################################################################

set -u

export WAYLAND_DISPLAY=""
export DOTFILES="/live/persistence/TailsData_unlocked/dotfiles"
export PERSISTENT="/live/persistence/TailsData_unlocked/Persistent"
export DATA_DIR="$PERSISTENT/.bitcoin"
export XDG_DATA_HOME="$DOTFILES/.local/share"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$DOTFILES/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$DOTFILES/.local/state}"
export ICON_FILE="$XDG_DATA_HOME/icons/bot128.png"
export ICON_ARG="--icon=$ICON_FILE"

# .desktop launchers (Apps menu) do not source ~/.profile, so PATH may be
# missing ~/.local/bin and $DOTFILES/.local/bin. Without those on PATH every
# `command -v bitcoind` / `command -v Sparrow` check below returns false and
# the UI incorrectly reports "Not installed". Prepend explicitly so detection
# works whether bot-menu was launched from a terminal or the Apps menu.
for _bot_path in "$HOME/.local/bin" "$DOTFILES/.local/bin"; do
    case ":$PATH:" in
        *":$_bot_path:"*) ;;
        *) export PATH="$_bot_path:$PATH" ;;
    esac
done
unset _bot_path

CHECK_KV_DIR="$XDG_CACHE_HOME/bot"
DIST_MARKER="$XDG_STATE_HOME/bot/dist"

# GPG fingerprint shown on About tab. Keep in sync with README.
GPG_FINGERPRINT="2EE3 5C29 41D5 4C9E 9E2D  C908 33A3 9346 82DD 9E18"
GPG_KEY_URL="https://sats.coffee/2EE35C2941D54C9E9E2DC90833A3934682DD9E18.asc"

# If yad is missing, offer to install it now (bundled .deb if available, else apt).
APT_TIMEOUT_SECS="${APT_TIMEOUT_SECS:-300}"
if ! command -v yad >/dev/null 2>&1; then
    if ! command -v zenity >/dev/null 2>&1; then
        echo "bot-menu requires yad. Install it with: sudo apt-get install -y yad" >&2
        exit 1
    fi
    if ! zenity --question --title="bot-menu requires yad" \
        --text="The Bitcoin on Tails control panel uses the <b>yad</b> GTK dialog toolkit (~600 KB) for its tabbed UI — zenity (which Tails ships) cannot do tabs or form layouts.\n\nInstall it now? You will be prompted for your <b>admin password</b>.\n\nIf you skip this, installs and updates from the terminal still work — only this graphical panel is unavailable." \
        --ok-label="Install" --cancel-label="Cancel" \
        --ellipsize "$ICON_ARG" 2>/dev/null; then
        exit 1
    fi
    if ! sudo -v 2>/dev/null; then
        zenity --error --title="Admin password required" \
            --text="An Administration Password is required to install yad.\n\nReboot Tails, click the <b>+</b> at the Welcome Screen, set an admin password, then re-open Bitcoin on Tails." \
            --ellipsize "$ICON_ARG" 2>/dev/null
        exit 1
    fi
    bundled_debs="$XDG_DATA_HOME/bot/debs"
    yad_glob=("$bundled_debs"/yad_*.deb)
    installed_ok=0
    if [ -e "${yad_glob[0]}" ] && [ -s "$bundled_debs/SHA256SUMS" ] \
        && grep -qv '^[[:space:]]*\(#\|$\)' "$bundled_debs/SHA256SUMS"; then
        if (cd "$bundled_debs" && sha256sum -c SHA256SUMS) && \
           timeout "$APT_TIMEOUT_SECS" sudo apt-get install -y "${yad_glob[@]}"; then
            installed_ok=1
        fi
    fi
    if ! ((installed_ok)); then
        timeout "$APT_TIMEOUT_SECS" sudo apt-get update -q && \
            timeout "$APT_TIMEOUT_SECS" sudo apt-get install -y yad && installed_ok=1
    fi
    if ! ((installed_ok)); then
        zenity --error --title="yad install failed" \
            --text="yad could not be installed (apt timed out or returned an error after ${APT_TIMEOUT_SECS}s). This is usually a slow or stuck Tor circuit. Check your network connection and try again." \
            --ellipsize "$ICON_ARG" 2>/dev/null
        exit 1
    fi
    # Re-exec ourselves now that yad is available.
    exec "$0" "$@"
fi

###############################################################################
# Helpers — gather live status. Each function MUST handle the
# "Bitcoin not installed yet" / "daemon not running" cases without erroring.
###############################################################################

get_bot_version() {
    if [ -x "$XDG_DATA_HOME/bot/b" ]; then
        "$XDG_DATA_HOME/bot/b" --version 2>/dev/null | sed 's/^Bitcoin on Tails //' || echo "unknown"
    else
        echo "unknown"
    fi
}

get_bitcoin_impl() {
    # Knots/Core both report version via --version. We detect by checking for
    # the Knots-specific string in the binary's version. The BIP-110 fork is
    # also a Knots build, so binary inspection alone can't tell us "this is
    # the BIP-110 build vs plain Knots" — the dist marker carries that.
    if command -v bitcoind >/dev/null 2>&1; then
        local marker_dist
        if [ -s "$DIST_MARKER" ]; then
            marker_dist="$(head -1 "$DIST_MARKER" | tr -d '[:space:]')"
        fi
        case "$marker_dist" in
            knots-bip110) echo "Bitcoin Knots + BIP-110" ; return ;;
        esac
        if bitcoind --version 2>/dev/null | grep -qi knots; then
            echo "Bitcoin Knots"
        else
            echo "Bitcoin Core"
        fi
    else
        echo "Not installed"
    fi
}

get_bitcoin_version() {
    if command -v bitcoind >/dev/null 2>&1; then
        bitcoind --version 2>/dev/null | head -1 | awk '{print $NF}' | sed 's/^v//'
    else
        echo "—"
    fi
}

get_sync_status() {
    # Use bitcoin-cli if running; otherwise report "Stopped".
    local info
    info=$(bitcoin-cli -datadir="$DATA_DIR" getblockchaininfo 2>/dev/null) || {
        echo "Daemon not running"
        return
    }
    local progress ibd
    progress=$(echo "$info" | grep verificationprogress | head -1 | sed 's/[^0-9.]//g')
    ibd=$(echo "$info" | grep initialblockdownload | head -1 | grep -oE 'true|false')
    if [ -z "$progress" ]; then
        echo "Syncing"
    else
        # Two-decimal percentage
        local pct
        pct=$(awk -v p="$progress" 'BEGIN{printf "%.2f", p*100}')
        if [ "$ibd" = "false" ]; then
            echo "Synced (${pct}%)"
        else
            echo "Initial sync (${pct}%)"
        fi
    fi
}

get_peer_count() {
    local peers
    peers=$(bitcoin-cli -datadir="$DATA_DIR" getpeerinfo 2>/dev/null) || {
        echo "—"
        return
    }
    local total onion
    total=$(echo "$peers" | grep -c '"id":')
    onion=$(echo "$peers" | grep -c '\.onion')
    echo "$total total ($onion onion)"
}

get_disk_free() {
    if [ -d "$DATA_DIR" ]; then
        df -h --output=avail "$DATA_DIR" 2>/dev/null | tail -1 | tr -d ' ' || echo "—"
    else
        echo "—"
    fi
}

get_prune_setting() {
    local settings="$DATA_DIR/settings.json"
    if [ ! -f "$settings" ]; then
        echo "Not configured"
        return
    fi
    local prune
    prune=$(grep '"prune":' "$settings" | cut -d\" -f4)
    if [ -z "$prune" ] || [ "$prune" = "0" ]; then
        echo "Disabled (full archival node)"
    else
        # MiB → GB for display
        local gb
        gb=$(( prune * 1024**2 / 10**9 ))
        echo "${gb} GB (${prune} MiB)"
    fi
}

get_network_mode() {
    local settings="$DATA_DIR/settings.json"
    if [ ! -f "$settings" ]; then
        echo "Not configured"
        return
    fi
    local proxy onion onlynet
    proxy=$(  grep '"proxy":'   "$settings" | cut -d\" -f4)
    onion=$(  grep '"onion":'   "$settings" | cut -d\" -f4)
    onlynet=$(grep '"onlynet":' "$settings" | cut -d\" -f4)
    if [ -z "$proxy" ] && [ -z "$onion" ]; then
        echo "Clearnet (no Tor — IP exposed)"
    elif [ "$onlynet" = "onion" ]; then
        echo "Tor only (onion peers only)"
    else
        echo "Tor (recommended)"
    fi
}

get_sparrow_version() {
    if command -v Sparrow >/dev/null 2>&1; then
        # Sparrow --version writes "Sparrow X.Y.Z" to stdout
        Sparrow --version 2>/dev/null | head -1 | awk '{print $NF}' || echo "installed"
    else
        echo "Not installed"
    fi
}

###############################################################################
# Update-check helpers — read KV files written by `install-{slug} --check`.
# bot-menu never runs --check itself unless the user clicks "Check for updates".
###############################################################################

# kv_get FILE KEY → echo value or empty.
kv_get() {
    [ -s "$1" ] || return 1
    awk -F= -v k="$2" '$1==k {sub(/^[^=]*=/, ""); print; exit}' "$1"
}

# active_dist → echoes "core" or "knots" based on the install marker, with
# bitcoind --version as fallback. Empty if neither is installed.
active_dist() {
    if [ -s "$DIST_MARKER" ]; then
        head -1 "$DIST_MARKER" | tr -d '[:space:]'
    elif command -v bitcoind >/dev/null 2>&1; then
        if bitcoind --version 2>/dev/null | grep -qi knots; then
            echo "knots"
        else
            echo "core"
        fi
    fi
}

# update_status_line SLUG → human one-liner derived from the cached KV.
# Returns "" if there's no cache yet.
update_status_line() {
    local kv="$CHECK_KV_DIR/check-$1.kv"
    [ -s "$kv" ] || { echo ""; return; }
    local label iv lv avail iso status
    label=$(kv_get "$kv" dist_label)
    iv=$(kv_get "$kv" installed_version)
    lv=$(kv_get "$kv" latest_version)
    avail=$(kv_get "$kv" update_available)
    iso=$(kv_get "$kv" last_check_iso)
    status=$(kv_get "$kv" check_status)
    if [ "$status" != "ok" ]; then
        echo "Last check failed (offline?) — $iso"
    elif [ "$avail" = "true" ]; then
        echo "Update available: $iv → $lv (last checked $iso)"
    elif [ -n "$lv" ]; then
        echo "Up to date: $lv (last checked $iso)"
    else
        echo "No check on file."
    fi
}

###############################################################################
# Build tab content
###############################################################################

build_status_tab() {
    local key=$1
    local dist; dist="$(active_dist)"
    local btc_update sparrow_update
    btc_update="$(update_status_line "${dist:-core}")"
    sparrow_update="$(update_status_line sparrow)"
    # "Check for BoT updates" — read-only check, no auto-install. Spawned in
    # a terminal so the user sees git fetch's progress; the script itself
    # pops a zenity dialog with the result.
    local cmd_bot_check_update
    cmd_bot_check_update="$(mk_action 'BoT — checking for updates' 'bot-check-update')"
    # Signaling line — surfaces the active soft-fork posture if non-default.
    # Only shown when the install marker says knots-bip110; otherwise the
    # field is omitted (yad just leaves it out, no empty row).
    local signaling=""
    if [ "$dist" = "knots-bip110" ]; then
        signaling="BIP-110 (rejecting non-OP_RETURN outputs >34 bytes / OP_RETURN >83 bytes)"
    fi

    if [ -n "$signaling" ]; then
        yad --plug="$key" --tabnum=1 \
            --form --columns=1 \
            --field="<b>Bitcoin on Tails</b>:LBL" "" \
            --field="Version:RO" "$(get_bot_version)" \
            --field="Check for BoT updates:FBTN" "$cmd_bot_check_update" \
            --field="<b>Node</b>:LBL" "" \
            --field="Implementation:RO" "$(get_bitcoin_impl)" \
            --field="Version:RO" "$(get_bitcoin_version)" \
            --field="Signaling:RO" "$signaling" \
            --field="Status:RO" "$(get_sync_status)" \
            --field="Peers:RO" "$(get_peer_count)" \
            --field="Updates:RO" "${btc_update:-Click \"Check for updates\" on the Bitcoin tab.}" \
            --field="<b>Storage</b>:LBL" "" \
            --field="Disk free:RO" "$(get_disk_free)" \
            --field="Prune setting:RO" "$(get_prune_setting)" \
            --field="<b>Wallet</b>:LBL" "" \
            --field="Sparrow:RO" "$(get_sparrow_version)" \
            --field="Updates:RO" "${sparrow_update:-Click \"Check for updates\" on the Sparrow tab.}" &
    else
        yad --plug="$key" --tabnum=1 \
            --form --columns=1 \
            --field="<b>Bitcoin on Tails</b>:LBL" "" \
            --field="Version:RO" "$(get_bot_version)" \
            --field="Check for BoT updates:FBTN" "$cmd_bot_check_update" \
            --field="<b>Node</b>:LBL" "" \
            --field="Implementation:RO" "$(get_bitcoin_impl)" \
            --field="Version:RO" "$(get_bitcoin_version)" \
            --field="Status:RO" "$(get_sync_status)" \
            --field="Peers:RO" "$(get_peer_count)" \
            --field="Updates:RO" "${btc_update:-Click \"Check for updates\" on the Bitcoin tab.}" \
            --field="<b>Storage</b>:LBL" "" \
            --field="Disk free:RO" "$(get_disk_free)" \
            --field="Prune setting:RO" "$(get_prune_setting)" \
            --field="<b>Wallet</b>:LBL" "" \
            --field="Sparrow:RO" "$(get_sparrow_version)" \
            --field="Updates:RO" "${sparrow_update:-Click \"Check for updates\" on the Sparrow tab.}" &
    fi
}

# Action-button helpers. yad FBTN runs the command through /bin/sh -c.
# We launch each action in a fresh terminal so the user sees the install
# script's output (these are interactive in --update mode).
#
# The terminal spawns `bash -lc` (login shell) so it sources ~/.profile and
# inherits PATH including ~/.local/bin / $DOTFILES/.local/bin. Without -l,
# bash -c runs as a non-login non-interactive shell with the .desktop
# launcher's stripped PATH and `b: command not found` follows.
mk_action() {
    # mk_action TITLE COMMAND
    local title="$1" cmd="$2"
    # Single-key wait. `-s` suppresses echoing the keypress (avoids garbled
    # "<key>command exited" footer), `-n 1` ends on first byte, and `-p`
    # writes the prompt to stderr so it shows even when stdout is buffered.
    # Trailing `echo` puts the cursor on a fresh line before the terminal
    # emulator paints its own "Process exited" footer.
    printf 'x-terminal-emulator -T %q -e bash -lc %q &' "$title" \
        "$cmd; echo; read -rsn 1 -p 'Press any key to close. ' _; echo"
}

build_bitcoin_tab() {
    local key=$1
    local dist; dist="$(active_dist)"
    local kv="$CHECK_KV_DIR/check-${dist:-core}.kv"
    local label iv lv chg status_line
    label=$(kv_get "$kv" dist_label || true)
    iv=$(kv_get "$kv" installed_version || true)
    lv=$(kv_get "$kv" latest_version || true)
    chg=$(kv_get "$kv" changelog_url || true)
    status_line="$(update_status_line "${dist:-core}")"
    [ -z "$status_line" ] && status_line="No check on file. Click \"Check for updates\" to fetch."

    # Live fallbacks so the tab is informative on first open (before any
    # --check has populated the KV cache).
    if [ -z "$label" ]; then
        case "$dist" in
            core)         label="Bitcoin Core"  ;;
            knots)        label="Bitcoin Knots" ;;
            knots-bip110) label="Bitcoin Knots + BIP-110" ;;
            "")           label="Not installed yet" ;;
            *)            label="$dist" ;;
        esac
    fi
    if [ -z "$iv" ] && [ -n "$dist" ]; then
        iv="$(get_bitcoin_version)"
    fi
    [ -z "$lv" ] && lv="(not checked yet)"

    # If Bitcoin is not actually installed (no marker, no bitcoind binary),
    # render a stripped-down tab that surfaces a single "Install Bitcoin"
    # call-to-action instead of a wall of stub buttons (Check for updates,
    # Update now, Uninstall) that all either no-op or re-launch `b`. This is
    # what the half-install recovery state looks like — scripts copied but
    # bitcoind never finished installing.
    if [ -z "$dist" ]; then
        local cmd_install
        cmd_install="$(mk_action 'BoT — install Bitcoin' 'b')"
        yad --plug="$key" --tabnum=2 \
            --form --columns=1 \
            --field="<b>Bitcoin not installed</b>:LBL" "" \
            --field=":LBL" "Bitcoin Core or Bitcoin Knots is not yet installed on this system. Click below to start the install flow — you'll pick which implementation and version to install." \
            --field="Install Bitcoin…:FBTN" "$cmd_install" &
        return
    fi

    local cmd_check cmd_update cmd_uninstall cmd_changelog cmd_storage cmd_network cmd_switch
    cmd_check="$(mk_action "BoT — checking $label" "install-$dist --check")"
    cmd_update="$(mk_action "BoT — updating $label" "install-$dist --update")"
    cmd_uninstall="$(mk_action "BoT — uninstalling $label" "install-$dist --uninstall")"
    cmd_storage="bot-set-prune >/dev/null 2>&1 &"
    cmd_network="bot-set-network >/dev/null 2>&1 &"
    cmd_switch="$(mk_action 'BoT — change implementation' 'bot-switch-impl')"
    if [ -n "$chg" ]; then
        cmd_changelog="xdg-open $(printf '%q' "$chg") >/dev/null 2>&1 &"
    else
        cmd_changelog="zenity --info --title='No release notes' --text='No changelog URL on file. Click Check for updates first.' --ellipsize $ICON_ARG &"
    fi

    # Surface active config on the tab so the user can see what they have
    # without opening the pickers.
    local prune_line network_line
    prune_line="$(get_prune_setting)"
    network_line="$(get_network_mode)"

    yad --plug="$key" --tabnum=2 \
        --form --columns=1 \
        --field="<b>${label}</b>:LBL" "" \
        --field="Installed version:RO" "${iv:-—}" \
        --field="Latest published:RO" "$lv" \
        --field="Status:RO" "$status_line" \
        --field="Storage (prune):RO" "$prune_line" \
        --field="Network:RO" "$network_line" \
        --field="Check for updates:FBTN" "$cmd_check" \
        --field="What's changed:FBTN" "$cmd_changelog" \
        --field="Update now:FBTN" "$cmd_update" \
        --field="Change storage…:FBTN" "$cmd_storage" \
        --field="Change network…:FBTN" "$cmd_network" \
        --field="Change implementation…:FBTN" "$cmd_switch" \
        --field="Uninstall:FBTN" "$cmd_uninstall" &
}

build_sparrow_tab() {
    local key=$1
    local kv="$CHECK_KV_DIR/check-sparrow.kv"
    local iv lv chg status_line installed
    iv=$(kv_get "$kv" installed_version || true)
    lv=$(kv_get "$kv" latest_version || true)
    chg=$(kv_get "$kv" changelog_url || true)
    status_line="$(update_status_line sparrow)"
    [ -z "$status_line" ] && status_line="No check on file. Click \"Check for updates\" to fetch."
    if [ -x "$DOTFILES/.local/bin/Sparrow" ]; then
        installed="Sparrow Wallet (installed)"
    else
        installed="Sparrow Wallet (not installed)"
    fi

    # Live fallbacks so first-open shows real data before --check has run.
    if [ -z "$iv" ] && [ -x "$DOTFILES/.local/bin/Sparrow" ]; then
        iv="$(get_sparrow_version)"
        # get_sparrow_version returns "Not installed" / "installed" sentinels
        # if --version doesn't parse — clamp those to empty so we show "—".
        case "$iv" in
            "Not installed"|"installed"|"") iv="" ;;
        esac
    fi
    [ -z "$lv" ] && lv="(not checked yet)"

    local cmd_check cmd_install cmd_update cmd_uninstall cmd_changelog
    cmd_check="$(mk_action 'BoT — checking Sparrow' 'install-sparrow --check')"
    cmd_install="$(mk_action 'BoT — installing Sparrow' 'install-sparrow')"
    cmd_update="$(mk_action 'BoT — updating Sparrow' 'install-sparrow --update')"
    cmd_uninstall="$(mk_action 'BoT — uninstalling Sparrow' 'install-sparrow --uninstall')"
    if [ -n "$chg" ]; then
        cmd_changelog="xdg-open $(printf '%q' "$chg") >/dev/null 2>&1 &"
    else
        cmd_changelog="zenity --info --title='No release notes' --text='No changelog URL on file. Click Check for updates first.' --ellipsize $ICON_ARG &"
    fi

    if [ -x "$DOTFILES/.local/bin/Sparrow" ]; then
        yad --plug="$key" --tabnum=3 \
            --form --columns=1 \
            --field="<b>$installed</b>:LBL" "" \
            --field="Installed version:RO" "${iv:-—}" \
            --field="Latest published:RO" "$lv" \
            --field="Status:RO" "$status_line" \
            --field="Check for updates:FBTN" "$cmd_check" \
            --field="What's changed:FBTN" "$cmd_changelog" \
            --field="Update now:FBTN" "$cmd_update" \
            --field="Uninstall:FBTN" "$cmd_uninstall" &
    else
        yad --plug="$key" --tabnum=3 \
            --form --columns=1 \
            --field="<b>$installed</b>:LBL" "" \
            --field="Status:RO" "Sparrow connects to your local Bitcoin node over RPC." \
            --field="Install Sparrow Wallet:FBTN" "$cmd_install" &
    fi
}

###############################################################################
# UTXOracle tab — surfaces the bundled `utxoracle` wrapper.
#
# License compliance: per the UTXOracle License v1.0, when displaying the
# script's outputs we must use the canonical names "UTXOracle Consensus Price"
# (24-hour daily average) and "UTXOracle Block Window Price" (last 144
# confirmed blocks). They appear verbatim in this tab.
###############################################################################
build_utxoracle_tab() {
    local key=$1
    local utxo_kv="$XDG_STATE_HOME/bot/utxoracle-last.kv"
    local utxo_py="$XDG_DATA_HOME/bot/utxoracle/UTXOracle.py"

    # If Bitcoin isn't installed yet, the wrapper has nothing to talk to.
    # Render an empty-state message instead of a wall of dead buttons.
    local dist; dist="$(active_dist)"
    if [ -z "$dist" ]; then
        yad --plug="$key" --tabnum=4 \
            --form --columns=1 \
            --field="<b>UTXOracle Price</b>:LBL" "" \
            --field=":LBL" "UTXOracle reads transaction data from your local Bitcoin node to derive a price — it cannot run until Bitcoin Core or Bitcoin Knots is installed.\n\nInstall Bitcoin from the Bitcoin tab first." &
        return
    fi
    if [ ! -s "$utxo_py" ]; then
        yad --plug="$key" --tabnum=4 \
            --form --columns=1 \
            --field="<b>UTXOracle bundle missing</b>:LBL" "" \
            --field=":LBL" "Expected $utxo_py.\nRe-run \`b\` to repair the BoT install." &
        return
    fi

    # Last-run summary from the wrapper's KV sidecar (one-shot CLI runs).
    local last_iso last_html last_line mode mode_label canonical
    last_iso=$(kv_get  "$utxo_kv" last_run_iso    || true)
    last_html=$(kv_get "$utxo_kv" last_html       || true)
    last_line=$(kv_get "$utxo_kv" last_price_line || true)
    mode=$(kv_get      "$utxo_kv" mode            || true)
    case "$mode" in
        block_window) mode_label="Last run: UTXOracle Block Window Price (most recent 144 confirmed blocks)" ;;
        consensus|*)  mode_label="Last run: UTXOracle Consensus Price (24-hour daily average)" ;;
    esac
    [ -z "$last_iso" ]  && last_iso="—"
    [ -z "$last_line" ] && last_line="(no run on file yet)"

    # Local HTTP server status (utxoracle-serve). Decoupled from the one-shot
    # wrapper above — the server runs in the background and refreshes on
    # each new confirmed block. Reading PID + healthz here is non-blocking.
    local server_port server_url server_status server_pid server_pid_file
    server_port="${UTXORACLE_SERVE_PORT:-17601}"
    server_url="http://127.0.0.1:$server_port"
    server_pid_file="${XDG_RUNTIME_DIR:-/tmp}/utxoracle-serve.pid"
    if [ -s "$server_pid_file" ]; then
        server_pid=$(cat "$server_pid_file" 2>/dev/null)
        if [ -n "$server_pid" ] && kill -0 "$server_pid" 2>/dev/null; then
            server_status="Running on $server_url (pid $server_pid)"
        else
            server_status="Stopped (stale PID file)"
        fi
    else
        server_status="Stopped"
    fi

    # Open-in-browser helper: prefer Tor Browser (correct on Tails), fall back
    # to xdg-open.  Used for local HTML files — NOT for 127.0.0.1 URLs because
    # Tor Browser routes localhost correctly but other apps (Onion Browser on
    # iOS, external devices) cannot reach 127.0.0.1 on this machine.
    local open_browser
    if command -v torbrowser-launcher >/dev/null 2>&1; then
        open_browser="torbrowser-launcher"
    elif [ -x /usr/local/bin/tor-browser ]; then
        open_browser="/usr/local/bin/tor-browser"
    else
        open_browser="xdg-open"
    fi

    # After running either utxoracle compute, relaunch bot-menu so the
    # "Last run" / "Last result" fields reflect the new KV without the user
    # having to close and reopen manually.
    # NOTE: must NOT use "bot-menu &" here — mk_action appends "; echo; read..."
    # and the "&;" combination is a POSIX syntax error that aborts the shell.
    # "exec bot-menu" replaces the bash process with bot-menu directly; the
    # trailing "; echo; read..." in the mk_action template is never reached
    # (exec replaces the process), so there is no "&;" and no syntax error.
    local refresh='pkill -f "yad --notebook" 2>/dev/null; sleep 0.5; exec bot-menu'

    # Action commands.
    local cmd_consensus cmd_block cmd_show cmd_serve_start cmd_serve_stop cmd_serve_status
    cmd_consensus="$(mk_action 'BoT — UTXOracle Consensus Price' "utxoracle; $refresh")"
    cmd_block="$(mk_action 'BoT — UTXOracle Block Window Price' "utxoracle -rb; $refresh")"
    if [ -n "$last_html" ] && [ -s "$last_html" ]; then
        cmd_show="$open_browser $(printf '%q' "$last_html") >/dev/null 2>&1 &"
    else
        cmd_show="zenity --info --title='No chart yet' \
            --text='Run UTXOracle Consensus Price or UTXOracle Block Window Price first to generate a chart.' \
            --ellipsize $ICON_ARG &"
    fi
    # Server controls — wrap in a terminal so users see start/stop output.
    cmd_serve_start="$(mk_action  'BoT — start utxoracle-serve'  'utxoracle-serve start')"
    cmd_serve_stop="$(mk_action   'BoT — stop utxoracle-serve'   'utxoracle-serve stop')"
    cmd_serve_status="$(mk_action 'BoT — utxoracle-serve status' 'utxoracle-serve status')"

    canonical="<b>UTXOracle</b> derives a Bitcoin price from <b>your own node's data only</b> — no third-party APIs, no IP leaks. Bundled snapshot from <tt>utxo.live</tt>; license preserved at <tt>$XDG_DATA_HOME/bot/utxoracle/LICENSE.txt</tt>.\n\n<b>Local HTTP price server (utxoracle-serve):</b> binds to <tt>127.0.0.1</tt> only, refreshes on each new confirmed block, exposes CoinGecko/Coinbase-shape endpoints + a native /price?date= for historical lookups. Accessible from Tor Browser on this Tails session only — external devices and other browsers (including Onion Browser on iOS) cannot reach 127.0.0.1 on this machine. From a terminal: <tt>btcprice</tt> for the latest price, <tt>btcprice 2024-04-15</tt> for a date."

    yad --plug="$key" --tabnum=4 \
        --form --columns=1 \
        --field="<b>UTXOracle one-shot</b>:LBL" "" \
        --field="Last run:RO"      "$last_iso" \
        --field="Last result:RO"   "$last_line" \
        --field="Mode:RO"          "$mode_label" \
        --field="Show last chart:FBTN"                                "$cmd_show" \
        --field="Compute UTXOracle Consensus Price (yesterday):FBTN"  "$cmd_consensus" \
        --field="Compute UTXOracle Block Window Price (last 144):FBTN" "$cmd_block" \
        --field="<b>Local price server</b>:LBL" "" \
        --field="Server status:RO" "$server_status" \
        --field="Start utxoracle-serve:FBTN" "$cmd_serve_start" \
        --field="Stop utxoracle-serve:FBTN"  "$cmd_serve_stop" \
        --field="Show server status:FBTN"    "$cmd_serve_status" \
        --field=":LBL" "$canonical" &
}

build_about_tab() {
    local key=$1
    local body
    body="<b>Bitcoin on Tails</b> $(get_bot_version)

A Bitcoin full-node installer for Tails OS. Installs Bitcoin Core or Bitcoin Knots, plus Sparrow Wallet as an optional add-on talking to your local node over RPC. UTXOracle is bundled for on-chain price discovery from your own node.

<b>Source:</b> <a href='https://github.com/satscoffee/bitcoin-on-tails'>github.com/satscoffee/bitcoin-on-tails</a>
<b>License:</b> MIT (BoT itself). UTXOracle is bundled under its own license — see <tt>$XDG_DATA_HOME/bot/utxoracle/LICENSE.txt</tt>.

<b>Verifying releases</b>

Releases are signed with GPG key:

<tt>$GPG_FINGERPRINT</tt>

Public key: <a href='$GPG_KEY_URL'>$GPG_KEY_URL</a>

Cross-check the fingerprint against an independent source before importing."

    yad --plug="$key" --tabnum=6 \
        --form --columns=1 \
        --text="$body" \
        --text-align=left &
}

###############################################################################
# Tx Inspector tab (v0.10) — cost-basis tracker
#
# Requires txindex=1.  If not enabled, the tab surfaces an enable button and
# explains the one-time reindex cost.  Once enabled, shows session history and
# a "Start new session" button.
###############################################################################
build_inspector_tab() {
    local key=$1
    local dist; dist="$(active_dist)"
    local session_dir="$XDG_DATA_HOME/bot/tx-inspector/sessions"

    # Not installed — can't use RPC at all.
    if [ -z "$dist" ]; then
        yad --plug="$key" --tabnum=5 \
            --form --columns=1 \
            --field="<b>Tx Inspector</b>:LBL" "" \
            --field=":LBL" "The Transaction Inspector requires a running Bitcoin node.\n\nInstall Bitcoin from the Bitcoin tab first." &
        return
    fi

    # Check txindex status (non-blocking — don't block the tab if bitcoind is slow).
    local txindex_ok=0
    if bcli_result=$(bitcoin-cli -datadir="$DATA_DIR" getindexinfo 2>/dev/null); then
        echo "$bcli_result" | python3 -c \
            "import json,sys; d=json.load(sys.stdin); exit(0 if 'txindex' in d else 1)" 2>/dev/null \
            && txindex_ok=1
    fi

    # Most-recent session summary (if any).
    local last_session="" last_session_label="(none yet)"
    last_session=$(ls -t "$session_dir"/session-*.json 2>/dev/null | head -1 || true)
    if [ -n "$last_session" ]; then
        local step_count created
        step_count=$(python3 -c \
            "import json; d=json.load(open('$last_session')); print(d.get('summary',{}).get('step_count',0))" \
            2>/dev/null || echo "?")
        created=$(python3 -c \
            "import json; d=json.load(open('$last_session')); print(d.get('created','')[:10])" \
            2>/dev/null || echo "")
        last_session_label="${created} — ${step_count} transaction(s)"
    fi

    local cmd_new cmd_resume cmd_report cmd_enable_txindex
    cmd_new="$(mk_action 'BoT — Transaction Inspector' 'bot-tx-inspector')"
    cmd_resume="$(mk_action 'BoT — Transaction Inspector (resume)' 'bot-tx-inspector --resume')"
    cmd_report="$(mk_action 'BoT — Tx Inspector report' "bot-tx-report")"
    cmd_enable_txindex="$(mk_action 'BoT — enable txindex' 'bot-tx-inspector')"  # inspector handles the prompt

    if (( txindex_ok )); then
        yad --plug="$key" --tabnum=5 \
            --form --columns=1 \
            --field="<b>Transaction Inspector</b>:LBL" "" \
            --field=":LBL" "Trace a chain of Bitcoin transactions and compute cost-basis, fees, and USD value at each step — using your local node and UTXOracle price data only. No external APIs." \
            --field="txindex status:RO" "Enabled ✓" \
            --field="<b>Sessions</b>:LBL" "" \
            --field="Most recent session:RO" "$last_session_label" \
            --field="Start new session:FBTN"    "$cmd_new" \
            --field="Resume last session:FBTN"  "$cmd_resume" \
            --field="Open last report:FBTN"     "$cmd_report" &
    else
        yad --plug="$key" --tabnum=5 \
            --form --columns=1 \
            --field="<b>Transaction Inspector</b>:LBL" "" \
            --field=":LBL" "Trace a chain of Bitcoin transactions and compute cost-basis, fees, and USD value at each step — using your local node and UTXOracle price data only." \
            --field="txindex status:RO" "Not enabled" \
            --field=":LBL" "<b>txindex=1 is required</b> to look up any transaction by ID.\n\n  • Adds ~40–50 GB extra disk (grows with the chain)\n  • One-time multi-hour reindex — Bitcoin runs in the background\n  • Click below to enable and restart Bitcoin automatically" \
            --field="Enable txindex &amp; reindex:FBTN" "$cmd_enable_txindex" &
    fi
}

###############################################################################
# Main
###############################################################################

main() {
    local key=$$
    build_status_tab "$key"
    build_bitcoin_tab "$key"
    build_sparrow_tab "$key"
    build_utxoracle_tab "$key"
    build_inspector_tab "$key"
    build_about_tab "$key"

    # Tab label "UTXOracle Price" — if it gets cut off in your install, swap to
    # "UTXOracle\nPrice" (yad accepts a literal newline in --tab labels).
    yad --notebook --key="$key" \
        --title="Bitcoin on Tails" \
        --tab="Status" --tab="Bitcoin" --tab="Sparrow" --tab="UTXOracle Price" \
        --tab="Tx Inspector" --tab="About" \
        --width=680 --height=560 \
        --button="gtk-close:0" \
        --image="$ICON_FILE" --image-on-top \
        "$ICON_ARG"

    # When the notebook closes, kill any leftover plug processes.
    pkill -P $$ -f "yad --plug=$key" 2>/dev/null || true
}

main "$@"
