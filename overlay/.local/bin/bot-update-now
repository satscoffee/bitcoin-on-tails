#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2026 Satoshi Coffee Co. — see LICENSE.
#
# bot-update-now — silent auto-update for Bitcoin on Tails.
#
# Called by bot-check-update (and only by bot-check-update) when the user
# clicks "Upgrade now" in the update-available dialog. The user already
# consented by clicking that button, so this script no longer prompts
# again — it shows a pulsating progress dialog during the clone/verify
# step, then hands off to `b` with BOT_AUTO_REFRESH=1 set so b runs the
# refresh path without showing the dev-choice dialog.
#
# Design notes (don't undo without reading the v0.11.1-alpha update-flow
# refactor in the ROADMAP):
#
#   - This script is invoked via `setsid bot-update-now </dev/null >/dev/null 2>&1 &`
#     so it has no controlling terminal. Any output goes to /dev/null. All
#     user-visible state must be conveyed via zenity dialogs.
#
#   - Previously this used `read -rp "Proceed? [y/N]"` inside a wrapping
#     terminal. That created a cascade of stale windows (terminal stayed
#     open with "press any key to close", killing it SIGHUP'd the new
#     bot-menu the update launched). Removing the terminal + the prompt
#     fixes that whole class of bugs.
#
#   - We set BOT_AUTO_REFRESH=1 before `exec b` so b auto-picks refresh
#     instead of showing the three-option dev-choice dialog (which would
#     stall the headless flow).

set -u

CLONE_URL="${BOT_CLONE_URL:-https://github.com/satscoffee/bitcoin-on-tails}"
CLONE_DIR="${BOT_CLONE_DIR:-$HOME/bot}"
EXPECTED_FINGERPRINT="${BOT_GPG_FINGERPRINT:-2EE3 5C29 41D5 4C9E 9E2D  C908 33A3 9346 82DD 9E18}"

ICON_FILE="$HOME/.local/share/icons/bot128.png"
ICON_ARG="--icon=$ICON_FILE"

# Optional log file for forensics if something goes wrong mid-clone.
# Nothing reads this — it exists so we can grep it from a terminal after
# the fact if a user reports a stuck update.
LOG_DIR="${XDG_STATE_HOME:-/live/persistence/TailsData_unlocked/dotfiles/.local/state}/bot"
mkdir -p "$LOG_DIR" 2>/dev/null
LOG="$LOG_DIR/bot-update-now.log"
exec 3>>"$LOG" 2>&1 || true
log() { printf '[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >&3 2>/dev/null; }

log "=== bot-update-now starting ==="
log "CLONE_URL=$CLONE_URL CLONE_DIR=$CLONE_DIR"

# ---- Progress dialog wraps the rm + clone -----------------------------------
#
# zenity --progress in pulsate mode shows a moving bar with no completion
# estimate (we can't predict how long Tor + GitHub will take). It runs as
# the foreground UI; we feed it status text via its stdin.
#
# The actual work runs in a subshell whose stdout drives zenity. When the
# subshell exits, --auto-close dismisses the progress window.

(
    echo "# Preparing..."
    log "Preparing"

    if [ -e "$CLONE_DIR" ]; then
        echo "# Removing previous install at $CLONE_DIR ..."
        log "rm -rf $CLONE_DIR"
        rm -rf "$CLONE_DIR" 2>&1 | while IFS= read -r line; do log "  rm: $line"; done
    fi

    echo "# Cloning latest BoT from GitHub over Tor (this can take a minute)..."
    log "git clone $CLONE_URL $CLONE_DIR"
    if ! git clone --quiet "$CLONE_URL" "$CLONE_DIR" >&3 2>&1; then
        log "git clone FAILED"
        echo "100"
        exit 11
    fi

    echo "# Verifying signed tag (best-effort)..."
    log "verifying latest tag"
    cd "$CLONE_DIR" || exit 12
    latest_tag=$(git describe --tags --abbrev=0 2>/dev/null || true)
    if [ -n "$latest_tag" ]; then
        if git tag -v "$latest_tag" 2>&1 | grep -qE 'Good signature|using.*key'; then
            log "tag $latest_tag signature OK"
        else
            log "tag $latest_tag signature could not be verified locally — informational only"
        fi
    fi

    echo "# Applying scripts and starting refreshed control panel..."
    log "handing off to b with BOT_AUTO_REFRESH=1"
    echo "100"
    exit 0
) | zenity --progress --pulsate --auto-close --no-cancel \
    --title="Bitcoin on Tails — updating" \
    --text="Updating Bitcoin on Tails..." \
    --width=480 "$ICON_ARG" --icon=bot128 2>/dev/null

work_rc="${PIPESTATUS[0]}"
log "subshell rc=$work_rc"

# ---- Failure path -----------------------------------------------------------
if [ "$work_rc" -ne 0 ]; then
    zenity --error --title="Update failed" \
        --text="The Bitcoin on Tails update did not complete (rc=$work_rc).\n\nThis is usually a Tor circuit problem during <tt>git clone</tt>. Try again in a moment, or update manually:\n\n<tt>rm -rf ~/bot \&amp;\&amp; git clone https://github.com/satscoffee/bitcoin-on-tails ~/bot \&amp;\&amp; ~/bot/b</tt>\n\nFull log: <tt>$LOG</tt>" \
        --width=560 "$ICON_ARG" --icon=dialog-error 2>/dev/null
    exit "$work_rc"
fi

# ---- Hand off to b ----------------------------------------------------------
# BOT_AUTO_REFRESH=1 tells b's already-installed branch to skip the
# refresh / menu / reinstall picker and run the refresh path directly.
# b will rsync the overlay, kill any leftover bot-menu (M1), and launch a
# fresh detached bot-menu (M2). See b's case "$dev_choice" branch.

log "exec $CLONE_DIR/b"
export BOT_AUTO_REFRESH=1
exec "$CLONE_DIR/b"
