###############################################################################
# Shared post-download body for install-core and install-knots.
#
# Source with no args to run the full install flow.
# Source with "--funcs-only" to just get env exports and helper functions.
#
# Required environment variables (caller must set before sourcing main flow):
#   DOMAIN                  e.g. "https://bitcoincore.org"
#   VER                     e.g. "28.2" or "28.1.knots20250417"
#   TAR_NAME                e.g. "bitcoin-$VER-x86_64-linux-gnu.tar.gz"
#   TAR_URL                 full URL to the tarball
#   SIGS_URL                full URL to SHA256SUMS (SHA256SUMS.asc expected alongside)
#   BINVERIFY_MIN_GOOD_SIGS integer (Core=3, Knots=1)
#   DIST_LABEL              prose name, e.g. "Bitcoin Core" or "Bitcoin Knots"
#   DIST_SLUG               short id, e.g. "core" or "knots" (used to invoke install-$DIST_SLUG on retry)
#   DOWNLOAD_DIR            caller's working directory (absolute path)
#
# builder-keys file must exist at $DOWNLOAD_DIR/builder-keys, one line per key
# in the format: "      Key fingerprint = XXXX XXXX ..."
###############################################################################

# Environment (idempotent)
export PATH="$HOME/.local/bin:$PATH"
export ICON=--icon="$HOME/.local/share/icons/bot128.png"
export WAYLAND_DISPLAY=""
export TMPDIR=${TMPDIR:-$XDG_RUNTIME_DIR}
export SOURCE="/live/persistence/TailsData_unlocked"
export DATA_DIR="$SOURCE/Persistent/.bitcoin"
export DOTFILES="$SOURCE/dotfiles"
export XDG_CONFIG_HOME="$DOTFILES/.config"
export XDG_CACHE_HOME="$DOTFILES/.cache"
export LOCAL_DIR="$DOTFILES/.local"
export XDG_STATE_HOME="$LOCAL_DIR/state"
export XDG_DATA_HOME="$LOCAL_DIR/share"
export BITCOIN_CHAINPARAMS_URL="https://raw.githubusercontent.com/bitcoin/bitcoin/master/src/kernel/chainparams.cpp"


# Look for good signatures
# Parameter 1 = Good Signatures required
check_sigs() {
    temp_file="$(mktemp)"
    trap 'rm -rf -- "$temp_file"' EXIT
    type=warning
    # shellcheck disable=SC2086
    keys="$(grep fingerprint $DOWNLOAD_DIR/builder-keys | sed 's/ //g' | cut -f2 -d= | shuf)"
    for key in $keys; do
        search_key
        (( good_sig < $1 )) || { type=info; break; }
    done
    zenity --$type --title="$good_sig of $1 good signatures found" --text="$(gpg --verify SHA256SUMS.asc SHA256SUMS 2>&1 | grep 'Good signature' | cut -c6-)" --no-markup --width=200 --no-wrap "$ICON" --timeout=10
    (( good_sig >= $1 ))
}


# Search and display key info
# Parameter 1 = (optional) fall back keyserver
search_key() {
    echo ''>"$temp_file"
    # shellcheck disable=SC2086
    { gpg --search-keys $1 "$key" >"$temp_file"; } & gpg_pid=$!
    [ -n "$1" ] || echo -e "\nSearching $key on openpgp.org keyserver..."
    until grep 'key' "$temp_file" >/dev/null; do
        sleep 1; printf '.'
        ps -p $gpg_pid &>/dev/null || break
    done
    pkill gpg &>/dev/null
    if grep '@' "$temp_file" >/dev/null; then
        sed -i 's/(1)/   /' "$temp_file"
        # shellcheck disable=SC2086
        if zenity --question --title='Do you trust this individual?' --no-markup --ellipsize \
        --text="$(<$temp_file)" "$ICON" --icon=auth-fingerprint; then
            # shellcheck disable=SC2086
            gpg $1 --recv-key "$key"
        else
            gpg --batch --yes --delete-keys "$key" &>/dev/null
        fi
    elif [ -n "$1" ]; then
        echo "$key not found."
    else
        echo "Searching $key on fallback keyserver.ubuntu.com keyserver..."
        search_key '--keyserver keyserver.ubuntu.com'
    fi
    good_sig=$(gpg --verify SHA256SUMS.asc SHA256SUMS 2>&1 | grep --count 'Good signature')
}


retry_on_fail() {
    echo "Running $*"
    until "$@"; do
        sleep $((retry++))
        echo "Retrying $*"
    done
}


###############################################################################
# Lifecycle helpers (--check / --update / --uninstall plumbing)
#
# These are pure helpers; they don't talk to the network and don't run
# zenity. Higher-level dispatch (bot_dispatch_bitcoin) is below.
###############################################################################

bot_state_dir()    { mkdir -p "$XDG_STATE_HOME/bot" 2>/dev/null; echo "$XDG_STATE_HOME/bot"; }
bot_cache_dir()    { mkdir -p "$XDG_CACHE_HOME/bot" 2>/dev/null; echo "$XDG_CACHE_HOME/bot"; }
bot_marker_path()  { echo "$(bot_state_dir)/dist"; }
bot_manifest_path(){ echo "$(bot_state_dir)/installed-files-${1}.txt"; }
bot_check_kv_path(){ echo "$(bot_cache_dir)/check-${1}.kv"; }
bot_latest_cache() { echo "$(bot_cache_dir)/latest-${1}.txt"; }

# bot_kv_get FILE KEY → echo value or empty. Tolerates spaces in value.
bot_kv_get() {
    [ -s "$1" ] || return 1
    awk -F= -v k="$2" '$1==k {sub(/^[^=]*=/, ""); print; exit}' "$1"
}

# bot_kv_write FILE key=val key=val ... → atomic full rewrite.
bot_kv_write() {
    local file="$1"; shift
    local tmp; tmp="$(mktemp "${file}.XXXXXX")" || return 1
    for kv in "$@"; do printf '%s\n' "$kv"; done > "$tmp"
    mv -f "$tmp" "$file"
}

# bot_get_installed_dist → echoes "core" / "knots" / empty. Reads marker first
# (cheap, deterministic). Falls back to parsing `bitcoind --version` output.
bot_get_installed_dist() {
    local m; m="$(bot_marker_path)"
    if [ -s "$m" ]; then
        head -1 "$m" | tr -d '[:space:]'
        return
    fi
    if command -v bitcoind >/dev/null 2>&1; then
        if bitcoind --version 2>/dev/null | grep -qi knots; then
            echo "knots"
        else
            echo "core"
        fi
    fi
}

bot_get_installed_version() {
    command -v bitcoind >/dev/null 2>&1 || return 1
    bitcoind --version 2>/dev/null | head -1 | awk '{print $NF}' | sed 's/^v//'
}

# bot_compare_versions A B → 0 equal, 1 A<B, 2 A>B (sort -V).
bot_compare_versions() {
    [ "$1" = "$2" ] && return 0
    local lo; lo="$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -1)"
    [ "$lo" = "$1" ] && return 1 || return 2
}

# bot_persistence_unlocked → 0 if dotfiles+persistent are writable, else 1.
bot_persistence_unlocked() {
    [ -d "$DOTFILES" ] && [ -w "$DOTFILES" ] && [ -d "$SOURCE/Persistent" ]
}

bot_daemon_running() {
    pgrep -x bitcoind >/dev/null 2>&1 || pgrep -x bitcoin-qt >/dev/null 2>&1
}

bot_data_dir_size_bytes() {
    [ -d "$DATA_DIR" ] || { echo 0; return; }
    du -sb "$DATA_DIR" 2>/dev/null | awk '{print $1}'
}

# bot_changelog_url SLUG VERSION → echoes upstream release-notes URL.
bot_changelog_url() {
    case "$1" in
        core)         echo "https://bitcoincore.org/en/releases/$2/" ;;
        knots)        echo "https://github.com/bitcoinknots/bitcoin/releases/tag/v$2" ;;
        knots-bip110) echo "https://github.com/dathonohm/bitcoin/releases/tag/v$2" ;;
        sparrow)      echo "https://github.com/sparrowwallet/sparrow/releases/tag/$2" ;;
        *)            echo "" ;;
    esac
}

# Cache helpers: latest-<slug>.txt holds the resolved upstream version.
# TTL gate so --check doesn't hammer upstream every minute when bot-menu refreshes.
: "${BOT_CHECK_TTL_SECS:=600}"

bot_latest_cache_fresh() {
    local f; f="$(bot_latest_cache "$1")"
    [ -s "$f" ] || return 1
    local mtime; mtime=$(stat -c %Y "$f" 2>/dev/null) || return 1
    local now; now=$(date +%s)
    (( now - mtime <= BOT_CHECK_TTL_SECS ))
}

bot_latest_cache_read() { cat "$(bot_latest_cache "$1")" 2>/dev/null; }

bot_latest_cache_write() {
    local f; f="$(bot_latest_cache "$1")"
    printf '%s\n' "$2" > "$f"
}

# bot_write_check_kv SLUG LATEST [STATUS] [INSTALLED_VERSION] [INSTALLED_PATH]
# Writes the KV file bot-menu reads. STATUS is optional (default "ok"); use
# "error" / "offline" when resolve_latest could not reach upstream.
#
# INSTALLED_VERSION and INSTALLED_PATH are optional overrides for callers
# whose installed version cannot be derived from the dist marker (e.g. the
# sparrow path: marker is "core" or "knots", so we'd otherwise look like a
# fresh install). Passing them here writes the final KV in a single atomic
# rename instead of forcing the caller to do a second rewrite — avoiding a
# race with bot-menu, which polls these files.
bot_write_check_kv() {
    local slug="$1" latest="$2" status="${3:-ok}"
    local override_ver="${4:-}" override_path="${5:-}"
    local installed_dist installed_ver update_avail size daemon_state persistence
    if [ -n "$override_ver" ]; then
        installed_ver="$override_ver"
    else
        installed_dist="$(bot_get_installed_dist)"
        if [ "$installed_dist" = "$slug" ]; then
            installed_ver="$(bot_get_installed_version || echo)"
        else
            installed_ver=""
        fi
    fi
    if [ -n "$installed_ver" ] && [ -n "$latest" ]; then
        bot_compare_versions "$installed_ver" "$latest"
        case $? in
            1) update_avail=true ;;
            *) update_avail=false ;;
        esac
    else
        update_avail=false
    fi
    size="$(bot_data_dir_size_bytes)"
    bot_daemon_running && daemon_state=true || daemon_state=false
    bot_persistence_unlocked && persistence=true || persistence=false
    local label src_url chg_url installed_path
    case "$slug" in
        core)         label="Bitcoin Core";          src_url="https://bitcoincore.org/bin/" ;;
        knots)        label="Bitcoin Knots";         src_url="https://bitcoinknots.org/files/" ;;
        knots-bip110) label="Bitcoin Knots + BIP-110"; src_url="https://github.com/dathonohm/bitcoin/releases" ;;
        sparrow)      label="Sparrow Wallet";        src_url="https://github.com/sparrowwallet/sparrow/releases" ;;
        *)            label="$slug";                 src_url="" ;;
    esac
    chg_url="$(bot_changelog_url "$slug" "$latest")"
    if [ -n "$override_path" ]; then
        installed_path="$override_path"
    else
        installed_path="$(command -v bitcoind 2>/dev/null || true)"
        [ "$slug" = "sparrow" ] && installed_path="$(command -v Sparrow 2>/dev/null || true)"
    fi
    bot_kv_write "$(bot_check_kv_path "$slug")" \
        "dist=$slug" \
        "dist_label=$label" \
        "installed_version=$installed_ver" \
        "installed_path=$installed_path" \
        "latest_version=$latest" \
        "update_available=$update_avail" \
        "last_check_unix=$(date +%s)" \
        "last_check_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        "source_url=$src_url" \
        "changelog_url=$chg_url" \
        "persistence_unlocked=$persistence" \
        "data_dir=$DATA_DIR" \
        "data_dir_size_bytes=${size:-0}" \
        "daemon_running=$daemon_state" \
        "check_status=$status"
}

###############################################################################
# bot_dispatch_bitcoin SLUG LABEL "$@"
#
# Shared --check / --update / --uninstall handler for Core and Knots. Caller
# must have defined a `${SLUG}_resolve_latest` function that echoes the latest
# upstream version on stdout (and only that), exiting non-zero on failure.
#
# When this function returns:
#   0 — mode handled, caller should `exit 0`
#   1 — no mode given, caller should fall through to interactive install
#   2 — bad mode, caller should exit non-zero
#
# Modes call `exit` directly on completion to keep the install body from
# running afterward. (Sourced scripts + early-return idiom.)
###############################################################################
bot_dispatch_bitcoin() {
    local slug="$1" label="$2"; shift 2
    local mode="${1:-}"

    case "$mode" in
        --check)
            local resolver="${slug}_resolve_latest"
            local latest="" status="ok"
            if bot_latest_cache_fresh "$slug"; then
                latest="$(bot_latest_cache_read "$slug")"
            elif latest="$("$resolver" 2>/dev/null)" && [ -n "$latest" ]; then
                bot_latest_cache_write "$slug" "$latest"
            else
                status="offline"
                latest="$(bot_latest_cache_read "$slug")"
            fi
            bot_write_check_kv "$slug" "$latest" "$status"
            # Print summary for CLI users.
            local iv; iv="$(bot_get_installed_version || echo "")"
            if [ -n "$latest" ] && [ -n "$iv" ] && [ "$iv" != "$latest" ]; then
                bot_compare_versions "$iv" "$latest"
                if [ $? -eq 1 ]; then
                    echo "$label: update available — installed $iv, latest $latest"
                    echo "Release notes: $(bot_changelog_url "$slug" "$latest")"
                else
                    echo "$label: installed $iv (newer than upstream latest $latest)"
                fi
            elif [ -n "$latest" ]; then
                echo "$label: up to date ($latest)"
            else
                echo "$label: could not reach upstream; using cached info if any"
            fi
            exit 0
            ;;
        --update)
            # Re-enter the installer with BOT_AUTO_LATEST=1 so the caller's
            # version-pick step picks the latest of the same major line and
            # skips interactive prompts.
            local installed_ver; installed_ver="$(bot_get_installed_version || echo "")"
            if [ -z "$installed_ver" ]; then
                echo "$label is not installed. Run \`b\` to install it." >&2
                exit 1
            fi
            export BOT_AUTO_LATEST=1
            export BOT_AUTO_LATEST_PIN_MAJOR="${installed_ver%%.*}"
            return 1   # caller falls through to install flow
            ;;
        --uninstall)
            bot_uninstall_bitcoin "$slug" "$label"
            exit 0
            ;;
        --help|-h)
            cat <<EOF
$label installer ($slug)

Usage:
  install-$slug                Interactive install / update
  install-$slug --check        Report installed + latest upstream version (no install)
  install-$slug --update       Install latest patch of the currently-installed major line
  install-$slug --uninstall    Remove $label binaries (with prompts to keep data)
  install-$slug --help         Show this message
EOF
            exit 0
            ;;
        "")
            return 1
            ;;
        *)
            echo "Unknown mode: $mode" >&2
            echo "Try: install-$slug --help" >&2
            exit 2
            ;;
    esac
}

# bot_uninstall_bitcoin SLUG LABEL — shared uninstall flow for Core and Knots.
# Always prompts. Defaults to KEEP for every prompt.
bot_uninstall_bitcoin() {
    local slug="$1" label="$2"
    local manifest; manifest="$(bot_manifest_path "$slug")"

    if ! command -v bitcoind >/dev/null 2>&1 && [ ! -s "$manifest" ]; then
        zenity --info --title="$label not installed" \
            --text="$label does not appear to be installed.\n\nNothing to uninstall." \
            --ellipsize "$ICON" --icon=bitcoin128 2>/dev/null || \
            echo "$label is not installed."
        return 0
    fi

    # Confirm before doing anything.
    if ! zenity --question --title="Uninstall $label?" \
        --text="This will remove $label binaries from your Persistent Storage.\n\nYou will be asked separately whether to keep your wallet, chain data, and settings.\n\nProceed?" \
        --ok-label="Continue" --cancel-label="Cancel" \
        --width=440 "$ICON" --icon=dialog-question 2>/dev/null; then
        return 0
    fi

    bot_daemon_running && stop-btc 2>/dev/null

    # Decision prompts — every default is "Keep".
    local del_chain=0 del_wallets=0 del_config=0
    if zenity --question --title="Delete chain data?" \
        --text="Delete the Bitcoin chain data?\n\nLocation: <tt>$DATA_DIR/blocks</tt>, <tt>chainstate</tt>, indexes\n\nThis is the synced blockchain. Deleting it means a future install will need to re-sync from scratch.\n\n<b>Default: keep.</b>" \
        --ok-label="Delete chain data" --cancel-label="Keep" --default-cancel \
        --width=440 "$ICON" --icon=drive-harddisk 2>/dev/null; then
        del_chain=1
    fi

    if zenity --question --title="Delete wallets?" \
        --text="Delete your Bitcoin wallet files?\n\nLocation: <tt>$DATA_DIR/wallets/</tt>\n\n<b>This is destructive — wallets contain your private keys.</b> Only do this if you have already backed up the wallets elsewhere or no longer need them.\n\n<b>Default: keep.</b>" \
        --ok-label="Delete wallets" --cancel-label="Keep" --default-cancel \
        --width=440 "$ICON" --icon=dialog-warning 2>/dev/null; then
        del_wallets=1
    fi

    if zenity --question --title="Delete config?" \
        --text="Delete <tt>bitcoin.conf</tt> and <tt>settings.json</tt>?\n\nLocation: <tt>$DATA_DIR/</tt> and <tt>$DOTFILES/.bitcoin/</tt>\n\n<b>Default: keep.</b>" \
        --ok-label="Delete config" --cancel-label="Keep" --default-cancel \
        --width=440 "$ICON" --icon=preferences-system 2>/dev/null; then
        del_config=1
    fi

    # Remove binaries via manifest if present, otherwise best-effort by name.
    # Defense in depth: reject absolute paths and any entry containing `..`,
    # so a tampered/malformed manifest can never escape the install prefix.
    if [ -s "$manifest" ]; then
        while IFS= read -r rel; do
            [ -z "$rel" ] && continue
            case "$rel" in
                /*|*..*) continue ;;
            esac
            rm -f "$LOCAL_DIR/$rel" 2>/dev/null
            rm -f "$DOTFILES/.local/$rel" 2>/dev/null
        done < "$manifest"
    fi
    # Belt-and-suspenders: known top-level binaries.
    for b in bitcoind bitcoin-qt bitcoin-cli bitcoin-tx bitcoin-util bitcoin-wallet test_bitcoin; do
        rm -f "$LOCAL_DIR/bin/$b" "$DOTFILES/.local/bin/$b" 2>/dev/null
    done

    # Conditional data removal.
    if (( del_wallets )); then
        rm -rf "$DATA_DIR/wallets" 2>/dev/null
    fi
    if (( del_chain )); then
        rm -rf "$DATA_DIR/blocks" "$DATA_DIR/chainstate" \
               "$DATA_DIR/indexes" "$DATA_DIR/mempool.dat" \
               "$DATA_DIR/peers.dat" "$DATA_DIR/anchors.dat" \
               "$DATA_DIR/banlist.json" "$DATA_DIR/fee_estimates.dat" 2>/dev/null
    fi
    if (( del_config )); then
        rm -f "$DATA_DIR/bitcoin.conf" "$DATA_DIR/settings.json" \
              "$DOTFILES/.bitcoin/bitcoin.conf" "$DOTFILES/.bitcoin/settings.json" \
              "$DOTFILES/.bitcoin/README.md" 2>/dev/null
    fi
    # Strip from PATH cache (autostart entries, mime overrides).
    rm -f "$DOTFILES/.config/autostart/bitcoin.desktop" 2>/dev/null

    # Forget the manifest and KV cache for this slug. Only drop the dist
    # marker if the binary is actually gone — if removal partially failed
    # (e.g. read-only path), keeping the marker means `b --update` can still
    # find and reinstall over the broken state instead of saying "not
    # installed" and forcing the user into a fresh interactive picker.
    rm -f "$manifest" \
          "$(bot_check_kv_path "$slug")" "$(bot_latest_cache "$slug")" 2>/dev/null
    if ! command -v bitcoind >/dev/null 2>&1 \
        && ! command -v bitcoin-qt >/dev/null 2>&1; then
        rm -f "$(bot_marker_path)" 2>/dev/null
        rm -f "$XDG_STATE_HOME/installed" 2>/dev/null
    fi

    zenity --info --title="$label uninstalled" \
        --text="$label has been removed.\n\nKept: $( ((del_chain)) || echo "chain data, ")$( ((del_wallets)) || echo "wallets, ")$( ((del_config)) || echo "config")$( ((del_chain && del_wallets && del_config)) && echo "(nothing)" )" \
        --ellipsize "$ICON" --icon=bitcoin128 2>/dev/null || \
        echo "$label uninstalled."
}


###############################################################################
# Storage / pruning UX. Used at first-install (no current value) and post-
# install via bot-set-prune (current value loaded from settings.json).
#
# bot_pick_prune AVAIL_GB BLOCKCHAIN_GB CHAINSTATE_GB [CURRENT_PRUNE_MIB]
#
# Prints the chosen prune_MiB to stdout (0 = full archival). Returns
# non-zero if the user cancels.
###############################################################################
bot_pick_prune() {
    local avail_gb="$1" bc_gb="$2" cs_gb="$3" current_mib="${4:-}"
    local space_after_cs recommended_gb rec_label rec_pre custom_pre archival_pre

    # Recommended size: keep available space minus chainstate minus a 10 GB
    # buffer, floor 2 GB. If the disk has room for archival, recommend that.
    space_after_cs=$(( avail_gb - cs_gb - 10 ))
    if (( space_after_cs > bc_gb )); then
        recommended_gb=0   # archival fits
        rec_label="Full archival — keep entire ~${bc_gb} GB blockchain (recommended: you have room)"
    else
        recommended_gb=$(( space_after_cs > 2 ? space_after_cs : 2 ))
        rec_label="Pruned to ${recommended_gb} GB (recommended for your disk size)"
    fi

    # Pre-select whichever option matches the current setting (post-install).
    rec_pre=TRUE; custom_pre=FALSE; archival_pre=FALSE
    if [ -n "$current_mib" ]; then
        local current_gb=$(( current_mib > 0 ? current_mib * 1024**2 / 10**9 : 0 ))
        if [ "$current_mib" = "0" ]; then
            rec_pre=FALSE; archival_pre=TRUE
        elif [ "$current_gb" = "$recommended_gb" ] && (( recommended_gb > 0 )); then
            : # already on rec_pre=TRUE
        else
            rec_pre=FALSE; custom_pre=TRUE
        fi
    fi

    local current_line=""
    if [ "$current_mib" = "0" ]; then
        current_line="\n\n<i>Current setting: full archival.</i>"
    elif [ -n "$current_mib" ] && (( current_mib > 0 )); then
        current_line="\n\n<i>Current setting: pruned to $((current_mib * 1024**2 / 10**9)) GB.</i>"
    fi

    local explainer
    explainer="<b>How much of the blockchain do you want on disk?</b>

<b>Pruned</b> (smaller, e.g. 10–100 GB)
  • Disk usage stays at your chosen size — the rest is discarded after validation.
  • You still validate every block — this is a full sovereign node.
  • Fine for using your own wallet privately.
  • Cannot serve historical blocks to other nodes.
  • Wallet backups older than your prune window need a re-sync to restore.

<b>Full archival</b> (~${bc_gb} GB and growing)
  • Stores the entire blockchain forever.
  • Helps strengthen the network by serving blocks to peers.
  • Can rescan any wallet from genesis without re-downloading.
  • Requires regular disk-space maintenance as the chain grows.${current_line}"

    local choice
    choice=$(zenity --list --radiolist \
        --title="Bitcoin storage settings" \
        --text="$explainer" \
        --column="Pick" --column="Mode" --column="Notes" \
        "$rec_pre"     "recommended" "$rec_label" \
        "$custom_pre"  "custom"      "Pruned to a custom size — you choose" \
        "$archival_pre" "archival"   "Full archival node (~${bc_gb} GB and growing)" \
        --width=760 --height=600 \
        "$ICON" --icon=bitcoin128) || return 1

    case "$choice" in
        recommended)
            if (( recommended_gb == 0 )); then
                echo 0
            else
                echo $(( recommended_gb * 10**9 / 1024**2 ))
            fi
            ;;
        custom)
            local pick_gb default_gb
            default_gb=$(( recommended_gb > 0 ? recommended_gb : 50 ))
            [ -n "$current_mib" ] && (( current_mib > 0 )) && \
                default_gb=$(( current_mib * 1024**2 / 10**9 ))
            pick_gb=$(zenity --scale \
                --title="Custom prune size" \
                --text="Choose how many GB of recent blockchain to keep:" \
                --min-value=2 --max-value="$bc_gb" \
                --value="$default_gb" --step=1 \
                "$ICON" --icon=bitcoin128) || return 1
            (( pick_gb < 2 )) && pick_gb=2
            echo $(( pick_gb * 10**9 / 1024**2 ))
            ;;
        archival)
            if (( avail_gb < bc_gb + cs_gb + 10 )); then
                if ! zenity --question \
                    --title="Disk may be too small for archival" \
                    --text="<b>Warning:</b> your USB has about ${avail_gb} GB free, but the full blockchain is ~${bc_gb} GB and grows over time. Bitcoin will likely run out of disk space.\n\nProceed with archival anyway?" \
                    --width=520 \
                    "$ICON" --icon=dialog-warning; then
                    return 1
                fi
            fi
            echo 0
            ;;
        *)
            return 1
            ;;
    esac
}


###############################################################################
# Network UX. Used at first-install (no current value) and post-install via
# bot-set-network (current value loaded from settings.json).
#
# bot_pick_network [CURRENT_PROXY] [CURRENT_ONION] [CURRENT_ONLYNET]
#
# Echoes the chosen mode token: "tor-only", "tor", or "clearnet".
# Returns non-zero if the user cancels.
#
# Mode mapping:
#   tor-only   proxy=127.0.0.1:9050  onion=127.0.0.1:9050  onlynet=onion
#   tor        proxy=127.0.0.1:9050  onion=127.0.0.1:9050  (no onlynet)
#   clearnet   (no proxy, no onion, no onlynet)
###############################################################################
bot_pick_network() {
    local cur_proxy="${1:-}" cur_onion="${2:-}" cur_onlynet="${3:-}"
    local pre_tor_only=FALSE pre_tor=FALSE pre_clearnet=FALSE current_line=""

    # Detect which preset matches the current settings.json. Empty proxy +
    # empty onion = clearnet. proxy set + onlynet=onion = Tor-only. Anything
    # else with proxy set = Tor (recommended).
    if [ -z "$cur_proxy" ] && [ -z "$cur_onion" ] && [ -z "$cur_onlynet" ]; then
        # First install — no current setting; default to Tor (recommended).
        pre_tor=TRUE
    elif [ -z "$cur_proxy" ] && [ -z "$cur_onion" ]; then
        pre_clearnet=TRUE
        current_line="\n\n<i>Current setting: Clearnet (no Tor).</i>"
    elif [ "$cur_onlynet" = "onion" ]; then
        pre_tor_only=TRUE
        current_line="\n\n<i>Current setting: Tor only (onion peers only).</i>"
    else
        pre_tor=TRUE
        current_line="\n\n<i>Current setting: Tor (recommended).</i>"
    fi

    local explainer
    explainer="<b>How should Bitcoin reach the network?</b>

<b>Tor only</b> — onion peers only
  • Most private — every peer is reached over Tor.
  • Smaller peer pool, so the initial sync runs slower.
  • Resistant to network surveillance and IP geolocation.

<b>Tor (recommended)</b> — Tor for everything, mixed peers
  • Your IP stays hidden — all traffic is routed through Tor.
  • Larger peer pool (onion + clearnet via Tor exits) → faster sync.
  • This is the BoT default and the right choice on Tails.

<b>Clearnet</b> — no Tor
  • <b>Will NOT work on a stock Tails system.</b> Tails firewalls all
    non-Tor traffic at the kernel level, so Bitcoin would silently
    fail to find any peers and never sync.
  • Useful only when this Persistent Storage USB is later booted on
    a regular Linux system (BoT's data lives on the USB, so it's
    portable).
  • Outside Tails: fastest connections, but every Bitcoin peer sees
    your real IP address.${current_line}"

    local choice
    choice=$(zenity --list --radiolist \
        --title="Bitcoin network settings" \
        --text="$explainer" \
        --column="Pick" --column="Mode" --column="Notes" \
        "$pre_tor_only" "tor-only" "Onion peers only — most private, slowest" \
        "$pre_tor"      "tor"      "All traffic via Tor — recommended (BoT default)" \
        "$pre_clearnet" "clearnet" "No Tor — won't work on stock Tails" \
        --width=760 --height=600 \
        "$ICON" --icon=bitcoin128) || return 1

    case "$choice" in
        tor-only)
            zenity --question \
                --title="Confirm: Tor only" \
                --text="<b>Tor only</b> connects to onion peers only. Initial blockchain sync will be slower than the recommended setting.\n\nProceed?" \
                --width=480 "$ICON" --icon=bitcoin128 || return 1
            echo "tor-only"
            ;;
        tor)
            echo "tor"
            ;;
        clearnet)
            zenity --question \
                --title="Clearnet mode — won't work on Tails" \
                --text="<b>Clearnet mode disables Tor for Bitcoin.</b>\n\n<b>On Tails (your current OS):</b> the Tails firewall blocks all non-Tor outbound traffic at the kernel. Bitcoin will appear to start but will silently never find any peers — no sync, no transactions, nothing.\n\n<b>Outside Tails:</b> this setting takes effect. Bitcoin connects directly to peers and your real IP address is visible to every one of them.\n\nPick this only if you plan to boot this USB on a regular Linux system. Proceed?" \
                --width=600 "$ICON" --icon=dialog-warning || return 1
            echo "clearnet"
            ;;
        *)
            return 1
            ;;
    esac
}


###############################################################################
# bot_remove_impl_binaries SLUG — silently remove a Bitcoin implementation's
# binaries (using the install manifest) without touching chain data, wallets,
# bitcoin.conf, or settings.json. No prompts, no zenity. Used by the switch-
# implementation flow where the user is intentionally swapping Core ↔ Knots
# (or reinstalling the same impl at a different version) and explicitly does
# NOT want to be asked about deleting their data on every transition.
#
# Returns 0 even if the manifest is missing — it's a best-effort cleanup so
# the subsequent install can lay down a clean tree without stale binaries
# (e.g. Core's bitcoin-tx left over after switching to Knots).
###############################################################################
bot_remove_impl_binaries() {
    local slug="$1"
    [ -n "$slug" ] || return 0
    local manifest; manifest="$(bot_manifest_path "$slug")"

    # Stop daemon — install scripts also do this, but if we leave it running
    # while ripping out binaries the user could end up with a half-running
    # bitcoind and a partially-replaced binary tree.
    bot_daemon_running && stop-btc 2>/dev/null

    # Remove files listed in the manifest, with the same path-traversal
    # guards as bot_uninstall_bitcoin so a tampered manifest can't escape
    # the install prefix.
    if [ -s "$manifest" ]; then
        local rel
        while IFS= read -r rel; do
            [ -z "$rel" ] && continue
            case "$rel" in
                /*|*..*) continue ;;
            esac
            rm -f "$LOCAL_DIR/$rel" 2>/dev/null
            rm -f "$DOTFILES/.local/$rel" 2>/dev/null
        done < "$manifest"
    fi
    # Belt-and-suspenders: known top-level Bitcoin binaries. Catches old
    # manifests that may not list every helper, and ensures no stale binary
    # from the previous impl survives `command -v bitcoind` etc.
    local b
    for b in bitcoind bitcoin-qt bitcoin-cli bitcoin-tx bitcoin-util bitcoin-wallet test_bitcoin; do
        rm -f "$LOCAL_DIR/bin/$b" "$DOTFILES/.local/bin/$b" 2>/dev/null
    done

    # Forget the old manifest + cached upstream-version probe. The dist
    # marker is intentionally NOT cleared here: the install script we exec
    # next will overwrite it with the new slug, and clearing it now would
    # briefly confuse `b --check` if anything ran in between.
    rm -f "$manifest" "$(bot_latest_cache "$slug")" "$(bot_check_kv_path "$slug")" 2>/dev/null

    return 0
}


# Early return for callers that just want env + helpers
[ "$1" = "--funcs-only" ] && return 0


###############################################################################
# Main install flow
###############################################################################

: "${DOMAIN:?bitcoin-install-common: DOMAIN not set by caller}"
: "${VER:?bitcoin-install-common: VER not set by caller}"
: "${TAR_NAME:?bitcoin-install-common: TAR_NAME not set by caller}"
: "${TAR_URL:?bitcoin-install-common: TAR_URL not set by caller}"
: "${SIGS_URL:?bitcoin-install-common: SIGS_URL not set by caller}"
: "${BINVERIFY_MIN_GOOD_SIGS:?bitcoin-install-common: BINVERIFY_MIN_GOOD_SIGS not set by caller}"
: "${DIST_LABEL:?bitcoin-install-common: DIST_LABEL not set by caller}"
: "${DIST_SLUG:?bitcoin-install-common: DIST_SLUG not set by caller}"
: "${DOWNLOAD_DIR:?bitcoin-install-common: DOWNLOAD_DIR not set by caller}"

[ -f "$DOWNLOAD_DIR/builder-keys" ] || { echo "bitcoin-install-common: missing $DOWNLOAD_DIR/builder-keys"; exit 1; }

set -m # Enable job control

# Download SHA256SUMS and SHA256SUMS.asc in background.
#
# `--timeout=60 --tries=10` caps per-attempt wait time. Tor circuits often
# return "Read error (Decryption has failed.) in headers" for the first few
# attempts before stabilizing — without this cap, wget can spin for minutes
# on bad circuits. retry_on_fail's outer loop will continue if all 10
# tries fail, but each cycle is bounded.
cd "$DOWNLOAD_DIR" || exit 1
retry_on_fail wget -cxnH --cut-dirs=5 --timeout=60 --tries=10 \
    -O "SHA256SUMS.tmp"     "$SIGS_URL"       & sig_dl_1=$!
retry_on_fail wget -cxnH --cut-dirs=5 --timeout=60 --tries=10 \
    -O "SHA256SUMS.asc.tmp" "${SIGS_URL}.asc" & sig_dl_2=$!

# Download binary tarball in background
mkdir -p "$DOWNLOAD_DIR/bitcoin-core-$VER"
retry_on_fail wget -cxnH --cut-dirs=5 --timeout=60 --tries=10 \
    -O "bitcoin-core-$VER/$TAR_NAME" "$TAR_URL" & get_core=$!

printf '\033]2;Getting %s trusted keys...\a' "$DIST_LABEL"
if OLD_VER=$(bitcoind --version 2>/dev/null); then
    action=update
    printf '\033]2;Updating all keys from keyserver...\a'
    gpg --refresh-keys
else
    action=installation
    # For single-signer dists (Knots, Knots+BIP-110), the relevant key was
    # already imported and stamped into builder-keys earlier in install-knots
    # / install-knots-bip110. We don't iterate the bundled trusted-keys dir
    # here because (a) only Core's multi-signer flow needs aggregation across
    # bundled keys, and (b) the iteration produces a misleading wall of
    # "trusted key X did not sign" warnings for keys that were never
    # candidate signers for this dist anyway.
    if [ -z "${SINGLE_SIGNER:-}" ]; then
        # Multi-signer (Core): import any bundled trusted-keys whose
        # fingerprint matches a builder-keys entry. Aggregation logic
        # downstream relies on ≥3 of those validating SHA256SUMS.asc.
        for key in ./trusted-keys/*; do
            [ -e "$key" ] || continue
            if grep "$(gpg --show-keys "$key" | grep 'Key fingerprint')" builder-keys; then
                gpg --import "$key"
            else
                echo "Warning: Bitcoin on Tails trusted key ${key/'./trusted-keys/'} did not sign $DIST_LABEL version $VER, skipping."
            fi
        done
    fi

    # Download chain parameters in the background to drive prune-size
    # suggestions. NOT critical for install — if the fetch hangs or fails
    # we fall back to hardcoded constants downstream. timeout/tries cap so
    # a stuck Tor circuit can't wedge the install.
    retry_on_fail wget --continue --timeout=30 --tries=3 \
        -O chainparams.cpp $BITCOIN_CHAINPARAMS_URL & get_size=$!
fi

printf '\033]2;Setup Persistent Storage...\a'
until [[ -f $XDG_STATE_HOME/tps_is_set_up ]]; do sleep 1; done

printf '\033]2;Getting %s signatures...\a' "$DIST_LABEL"
wait $sig_dl_1 $sig_dl_2
mv -f SHA256SUMS.tmp     SHA256SUMS
mv -f SHA256SUMS.asc.tmp SHA256SUMS.asc
cd "bitcoin-core-$VER" || exit 1
mv -f "$DOWNLOAD_DIR"/SHA256SUMS{,.asc} .

if [ ! -f SHA256SUMS ]; then
    zenity --error --title="Signature file not found" --text="Click OK to try downloading $DIST_LABEL again." --ellipsize "$ICON" && \
    "install-$DIST_SLUG"
    exit 1
fi

who_trusts="the Bitcoin on Tails maintainers"
while true; do
    printf '\033]2;Verify checksum signatures...\a'
    good_sig=$(gpg --verify SHA256SUMS.asc SHA256SUMS 2>&1 | grep --count 'Good signature')
    if ((good_sig >= BINVERIFY_MIN_GOOD_SIGS)); then
        # Single-signer distributions (e.g. Knots, signed only by Luke Dashjr)
        # have no additional signers to promote to, so skip the multi-sig prompt.
        if [ -n "$SINGLE_SIGNER" ]; then
            zenity --notification --text="$DIST_LABEL download verified by $good_sig signature from the release signer." --icon=checkbox-checked
            break
        fi
        zenity --question --title='Further download verification' --text="Your $DIST_LABEL download has been successfully verified by $good_sig signatures from individuals trusted by $who_trusts.\n\nFurther download verification is optional. It requires around 5 to 10 minutes.\n\nPerforming additional verification gives further assurance you have not downloaded an unexpected or tampered version of Bitcoin." --cancel-label='Continue Setup' --default-cancel --ok-label='More Verification' "$ICON" --icon=gtk-dialog-authentication
        verified=$?
        ((verified)) && break
        ((BINVERIFY_MIN_GOOD_SIGS++))
    else
        zenity --warning --title="Verify $DIST_LABEL download" --text='Download verification is required.\n\nPerforming the verification steps ensures that you have not downloaded an unexpected or tampered version of Bitcoin, which may result in loss of funds.' --ok-label='Verify Now' "$ICON" --icon="gtk-dialog-authentication"
        verified=0
    fi
    [[ "$who_trusts" == "you" ]] || zenity --info --title="Choose trustworthy individuals" --text="$DIST_LABEL releases are signed by a number of individuals, each with a unique public key. You decide which of these public keys you trust.\n\nTo validate your download's signatures, choose a few individuals who you find trustworthy." "$ICON" --icon=security-high
    who_trusts="you"
    check_sigs "$BINVERIFY_MIN_GOOD_SIGS" || BINVERIFY_MIN_GOOD_SIGS=$((BINVERIFY_MIN_GOOD_SIGS > 1 ? 3 : 1))
done

printf '\033]2;Downloading %s...\a' "$DIST_LABEL"
ps -p $get_core &>/dev/null && fg %"$(jobs -l | grep $get_core | cut -f1 -d' ' | tr -c -d '[:digit:]')"
# Verify download integrity
if file_name=$(sha256sum --ignore-missing --check SHA256SUMS); then
    zenity --notification --text="$DIST_LABEL download integrity successfully verified." --icon=checkbox-checked
    stop-btc
else
    zenity --error --title="Download integrity failure" --text="Checksum does not match what was expected.\n\nClick OK to try downloading $DIST_LABEL again." --ellipsize "$ICON" && \
    "install-$DIST_SLUG"
    exit 1
fi
printf '\033]2;Installing %s...\a' "$DIST_LABEL"
# Capture install manifest BEFORE extracting so --uninstall can find what to
# remove later. Drop the top-level archive directory (matches --strip-components=1)
# and skip directory entries.
mkdir -p "$XDG_STATE_HOME/bot" 2>/dev/null
tar -tf "${file_name::-4}" \
    | sed 's|^[^/]*/||' \
    | grep -v '/$' \
    | grep -v '^$' \
    > "$XDG_STATE_HOME/bot/installed-files-$DIST_SLUG.txt" 2>/dev/null || true
tar -xvf "${file_name::-4}" --strip-components=1 --directory=$LOCAL_DIR
# Record which implementation is installed so b/bot-menu/--check can route.
echo "$DIST_SLUG" > "$XDG_STATE_HOME/bot/dist" 2>/dev/null || true
rm -Rvf "$DOWNLOAD_DIR"/{download*,*.tmp,wget-log*,bin-index}
until [ -f $XDG_DATA_HOME/bot/b ]; do sleep 1; done
# Change mime association from electrum to bitcoin core
sed 's/bitcoin=electrum/bitcoin=bitcoin-qt/g' /usr/share/applications/mimeinfo.cache > "$XDG_DATA_HOME/applications/mimeinfo.cache"
# Configure data directory
rsync -vhb --remove-source-files "$LOCAL_DIR"/{bitcoin.conf,README.md} $DOTFILES/.bitcoin
sed -i 's/#rpcport=<port>/rpcport=17600/' "$DOTFILES/.bitcoin/bitcoin.conf"     # set -rpcport for Tails
sed -i "s,#datadir=<dir>,datadir=$DATA_DIR," "$DOTFILES/.bitcoin/bitcoin.conf"  # set -datadir for Tails
sed -i "s,#debuglogfile=<file>,debuglogfile=$HOME/.bitcoin/debug.log," "$DOTFILES/.bitcoin/bitcoin.conf" # set log to tmpfs
link-dotfiles
printf "\033]2;%s %s complete!\a" "$DIST_LABEL" "$action"

if [ -e $XDG_STATE_HOME/installed ] && [ -n "$OLD_VER" ]; then
    new_ver=$(bitcoind --version 2>/dev/null | head -1 | awk '{print $NF}')
    zenity --info --title='Update successful' --text="${OLD_VER%%Copyright*}was updated to $new_ver" "$ICON" --icon=bitcoin128 &
else
    # Reap the background chainparams.cpp fetch. We use `wait` rather than
    # `fg` so a killed/timed-out wget doesn't hang the install — fg would
    # try to bring the (already-dead) job to the foreground.
    wait "$get_size" 2>/dev/null || true

    # Default fallback values if the chainparams fetch failed or hung.
    # These are deliberately a touch conservative — slightly oversizing
    # the chain estimate just makes the prune picker more cautious.
    # Numbers tracked from Core master ~mid-2026; bump on major chain milestones.
    assumed_blockchain_size=700        # GB
    assumed_chain_state_size=10        # GB
    if [ -s "$DOWNLOAD_DIR/chainparams.cpp" ]; then
        cps_size=$(grep --max-count=1 m_assumed_chain_state_size "$DOWNLOAD_DIR/chainparams.cpp" 2>/dev/null | sed 's/[^0-9]*//g')
        cps_blk=$( grep --max-count=1 m_assumed_blockchain_size  "$DOWNLOAD_DIR/chainparams.cpp" 2>/dev/null | sed 's/[^0-9]*//g')
        [ -n "$cps_size" ] && assumed_chain_state_size="$cps_size"
        [ -n "$cps_blk"  ] && assumed_blockchain_size="$cps_blk"
    else
        echo "Warning: chainparams.cpp fetch failed or timed out; using fallback values (chain ~${assumed_blockchain_size} GB / chainstate ~${assumed_chain_state_size} GB) for prune sizing." >&2
    fi
    # Move completed verified download to persistent storage. When persistence
    # was already up at download time, $DOWNLOAD_DIR is *already inside*
    # $XDG_DATA_HOME/bitcoin — making this a no-op self-rsync that errors out
    # with "Skipping sender remove" warnings (exit 23). Detect that and skip.
    download_real="$(readlink -f "$DOWNLOAD_DIR" 2>/dev/null)"
    target_real="$(readlink -f "$XDG_DATA_HOME/$(basename "$DOWNLOAD_DIR")" 2>/dev/null)"
    if [ -n "$download_real" ] && [ "$download_real" = "$target_real" ]; then
        echo "Download already in persistent storage at $DOWNLOAD_DIR — skipping rsync."
    else
        rsync -vh --remove-source-files --recursive "$DOWNLOAD_DIR" "$XDG_DATA_HOME" || true
    fi

    mkdir -p "$DATA_DIR"/{wallets,blocks}
    # Make wallets writable in case a previous install left it chmod -w'd
    # below. Without this, the `ln` calls fail to create their backup file
    # and abort with "Permission denied".
    chmod +w "$DATA_DIR/wallets" 2>/dev/null || true
    # Drop `-b` (backup) from these ln invocations: with --force we don't
    # need a backup of the previous symlink, and -b creating a `.~` file in
    # a chmod'd-readonly dir was the actual cause of the permission errors.
    ln --symbolic --force /media/"$USER" "$DATA_DIR/wallets" 2>/dev/null || true
    chmod -w "$DATA_DIR/wallets"  # TODO: this can be deleted when panic mode is added
    ln --symbolic --force {"$HOME"/.bitcoin,$DATA_DIR}/debug.log 2>/dev/null || true
    ln --symbolic --force $DOTFILES/.bitcoin/{README.md,bitcoin.conf} $DATA_DIR 2>/dev/null || true
    # Calculate space available for block file storage
    avail_gb=$(($(df --output=avail $SOURCE | tail -1) * 1024 / 10 ** 9))
    # Ask the user how much of the chain to keep. The picker presents a
    # recommendation tailored to free disk space (archival if there's room,
    # otherwise pruned-to-fit) plus custom and archival overrides. If the
    # user cancels we fall back to the auto-calculated value (legacy
    # behavior, never wedges the install).
    if ! prune_MiB=$(bot_pick_prune "$avail_gb" "$assumed_blockchain_size" "$assumed_chain_state_size"); then
        space=$(( avail_gb - assumed_chain_state_size - 10 ))
        auto_prune_GB=$(( space > 2 ? space : 2 ))
        prune_MiB=$(( space > assumed_blockchain_size ? 0 : auto_prune_GB * 10 ** 9 / 1024 ** 2 ))
    fi
    if (( prune_MiB > 0 )); then
        prune_GB=$(( prune_MiB * 1024**2 / 10**9 ))
    else
        prune_GB=0
    fi
    # Cache chainparams.cpp into a stable location so bot-set-prune can read
    # the same assumed sizes later without a fresh network probe.
    install -D -m 0644 "$DOWNLOAD_DIR/chainparams.cpp" \
        "$XDG_DATA_HOME/bot/chainparams.cpp" 2>/dev/null || true

    # Ask which network mode to use. Falls back to Tor (recommended) on cancel
    # so the install never wedges and the user is never accidentally on
    # clearnet with their IP exposed.
    network_mode=$(bot_pick_network) || network_mode="tor"
    case "$network_mode" in
        tor-only)
            cat > "$DATA_DIR/settings.json" <<JSON
{
    "dbcache": "450",
    "onion": "127.0.0.1:9050",
    "proxy": "127.0.0.1:9050",
    "onlynet": "onion",
    "prune": "$prune_MiB",
    "server": true
}
JSON
            ;;
        clearnet)
            cat > "$DATA_DIR/settings.json" <<JSON
{
    "dbcache": "450",
    "prune": "$prune_MiB",
    "server": true
}
JSON
            ;;
        tor|*)
            cat > "$DATA_DIR/settings.json" <<JSON
{
    "dbcache": "450",
    "onion": "127.0.0.1:9050",
    "proxy": "127.0.0.1:9050",
    "prune": "$prune_MiB",
    "server": true
}
JSON
            ;;
    esac


    if ((prune_MiB)); then
        storageRequiresMsg="Approximately $((prune_GB + assumed_chain_state_size)) GB of data will be stored in your Persistent Storage."
        expected_backup_days=$((prune_GB * 10**9 / (2250000 * 86400 / 600)))
        prune_explanation="\n\nBitcoin on Tails has chosen to limit block chain storage (pruning) to $prune_GB GB (sufficient to restore backups $expected_backup_days days old), the historical data must still be downloaded and processed, but will be deleted afterward to keep your disk usage low."
    else
        storageRequiresMsg="At least $((assumed_blockchain_size + assumed_chain_state_size)) GB of data will be stored in your Persistent Storage, and it will grow over time."
    fi
    zenity --info --title Welcome --icon=bitcoin128 --text="<i>Welcome to $DIST_LABEL.</i>\n\n
$DIST_LABEL will download and store a copy of the Bitcoin block chain. $storageRequiresMsg\n
$DIST_LABEL has begun to download and process the full Bitcoin block chain ($assumed_blockchain_size GB) starting with the earliest transactions in 2009 when Bitcoin initially launched.\n
This initial synchronisation is very demanding, and may expose hardware problems with your computer that had previously gone unnoticed. Each time you run Bitcoin Core, it will continue downloading where it left off.$prune_explanation" "$ICON" &
    # shellcheck source=/dev/null
    . "$HOME"/.profile
fi
wrapped bitcoin-qt -min -startupnotify=link-dotfiles
wait
touch $XDG_STATE_HOME/installed
