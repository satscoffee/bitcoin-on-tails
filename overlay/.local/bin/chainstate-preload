#################################################
# autostart: Preloads the chainstate into memory while waiting to connect to peers.
# quits as soon as progress is made, RAM is full or chainstate is loaded.
#################################################

export ICON="--icon=$HOME/.local/share/icons/bot128.png"
total_mem=$(awk 'NR==1 {print $2}' /proc/meminfo)

cd /live/persistence/TailsData_unlocked/Persistent/.bitcoin || exit 1
if ! grep 'progress=0.999' debug.log; then
    sleep 30
    if passwd -S "$USER" | grep NP; then
        zenity --info --title='Remember to lock your screen' --text='Lock your screen before stepping away from the PC.\n\nSynchronizing Bitcoin Core may take a while...' --icon=system-lock-screen "$ICON" --timeout=10 &
        tails-screen-locker
    fi
else
    sleep 200
    if passwd -S "$USER" | grep NP; then
        zenity --info --title='Remember to lock your screen' --text='Always lock your screen before stepping away from the PC.' --icon=system-lock-screen "$ICON" --timeout=5 &
        tails-screen-locker
    fi
fi &>/dev/null &

until grep 'progress=0.999' debug.log; do
    cat chainstate/* &> /dev/null & full_speed=$!
    # exit when free memory <10% total memory
    if (( $(awk 'NR==2 {print $2}' /proc/meminfo)*100/total_mem < 10 )); then
        kill $full_speed &>/dev/null
        {
            zenity --info --title='Your computer is low on memory' --text='Additional RAM might significantly improve sync performance.' "$ICON" --icon=drive-harddisk-solidstate --timeout=6
            sleep 60
        } &
        exit 1
    fi
    sleep $((++i))
    # exit if cat command finishes and can't be killed. Means entire chainstate was preloaded.
    if ! kill $full_speed &>/dev/null; then
        zenity --info --title='Chainstate preloaded to RAM' --text='Bitcoin chainstate preloaded to memory.' "$ICON" --icon=drive-harddisk-solidstate --timeout=4
        sleep 20
        exit 0
    fi
done
