#!/bin/bash
# SPDX-License-Identifier: MIT
# Copyright (c) 2026 Satoshi Coffee Co. — see LICENSE.
#
# bot-check-update — check whether the installed BoT clone is behind origin,
# and surface results in a yad dialog where the manual update commands are
# selectable/copyable text. Also offers an "Auto-update now" button that
# runs `bot-update-now` in a fresh terminal.
#
# Does NOT install anything by itself.

set -u

# Force GTK to X11 (Xwayland) for the yad form below — native Wayland
# segfaults yad's GtkSocket widget on Tails 7.x.
export GDK_BACKEND=x11

DOTFILES="${DOTFILES:-/live/persistence/TailsData_unlocked/dotfiles}"
INSTALLED_BOT_DIR="${INSTALLED_BOT_DIR:-$DOTFILES/.local/share/bot}"
ICON_FILE="$HOME/.local/share/icons/bot128.png"
ICON_ARG="--icon=$ICON_FILE"

# bot_raise_dialog fallback
type bot_raise_dialog >/dev/null 2>&1 || bot_raise_dialog() {
    local title="$1"
    [ -z "$title" ] && return 0
    (
        local i=0 wid=""
        while [ "$i" -lt 12 ]; do
            sleep 0.3
            command -v wmctrl >/dev/null 2>&1 && wmctrl -F -a "$title" 2>/dev/null && break
            if command -v xdotool >/dev/null 2>&1; then
                wid=$(xdotool search --name "$title" 2>/dev/null | tail -1)
                [ -n "$wid" ] && xdotool windowactivate "$wid" 2>/dev/null && break
            fi
            i=$((i+1))
        done
    ) >/dev/null 2>&1 &
}

# NOTE: This script used to spawn the auto-update in a new terminal via a
# helper called mk_terminal_action. That created a cascade of stale windows
# the user had to manually close after every update (the wrapping terminal
# left a "press any key to close" prompt, the SIGHUP from closing it would
# kill the new bot-menu the update just launched, and the original menu
# stayed underneath everything). The new flow runs bot-update-now silently
# in the background with stdio fully detached via setsid — bot-update-now
# does all its own UI via zenity dialogs.

# --- Validate state ---------------------------------------------------------

if [ ! -d "$INSTALLED_BOT_DIR/.git" ]; then
    msg="The installed BoT directory at\n<tt>$INSTALLED_BOT_DIR</tt>\nisn't a git checkout, so I can't check for updates against origin.\n\nTo get update checking, re-install via:\n\n<tt>rm -rf ~/bot &amp;&amp; git clone https://github.com/satscoffee/bitcoin-on-tails ~/bot &amp;&amp; ~/bot/b</tt>"
    bot_raise_dialog "Cannot check for updates"
    if command -v zenity >/dev/null 2>&1; then
        zenity --warning --title="Cannot check for updates" --text="$msg" --width=520 \
            "$ICON_ARG" --icon=dialog-warning 2>/dev/null
    fi
    echo "bot-check-update: $INSTALLED_BOT_DIR is not a git checkout."
    exit 1
fi

cd "$INSTALLED_BOT_DIR" || exit 1

remote=$(git remote 2>/dev/null | head -1)
remote="${remote:-origin}"
default_branch=$(git symbolic-ref --short "refs/remotes/$remote/HEAD" 2>/dev/null \
                 | sed "s|^$remote/||" || true)
default_branch="${default_branch:-main}"

local_ver=$(./b --version 2>/dev/null | sed 's/^Bitcoin on Tails //')
[ -z "$local_ver" ] && local_ver="(unknown)"

echo "Checking for BoT updates against $remote/$default_branch over Tor..."

# --- Fetch ------------------------------------------------------------------
#
# Show a pulsating progress dialog while git fetch runs. Tor circuits can
# make this take 5-30 seconds; without a visible indicator the user sees
# nothing happen and clicks the menu button a second time, spawning a
# second fetch. The progress dialog is auto-closed when fetch returns.
#
# We capture fetch's exit code via a temp file because piping to zenity
# eats the exit status. Tee'd to stderr too for terminal-mode debugging.

bot_raise_dialog "Checking for BoT updates"
fetch_status_file=$(mktemp)
trap 'rm -f "$fetch_status_file"' EXIT

(
    timeout 30 git fetch --tags --force "$remote" "$default_branch" >&2
    echo $? > "$fetch_status_file"
) | zenity --progress --pulsate --auto-close --no-cancel \
    --title="Checking for BoT updates" \
    --text="Fetching latest tags from $remote over Tor..." \
    --width=420 "$ICON_ARG" --icon=bot128 2>/dev/null || true

fetch_rc=$(cat "$fetch_status_file" 2>/dev/null || echo 1)
if [ "$fetch_rc" -ne 0 ]; then
    bot_raise_dialog "Update check failed"
    zenity --error --title="Update check failed" \
        --text="Could not reach GitHub to check for BoT updates.\n\nThis is usually a slow or stuck Tor circuit. Try:\n\n  1. Wait a moment and click <b>Check for Updates</b> again\n  2. Or update manually — open a terminal and run:\n\n<tt>rm -rf ~/bot \&amp;\&amp; git clone https://github.com/satscoffee/bitcoin-on-tails ~/bot \&amp;\&amp; ~/bot/b</tt>\n\n     Then pick <b>refresh</b> to apply the latest scripts." \
        --width=560 "$ICON_ARG" --icon=dialog-error 2>/dev/null
    exit 2
fi

behind=$(git rev-list --count "HEAD..$remote/$default_branch" 2>/dev/null || echo 0)
ahead=$(git  rev-list --count "$remote/$default_branch..HEAD" 2>/dev/null || echo 0)
latest_tag=$(git describe --tags --abbrev=0 "$remote/$default_branch" 2>/dev/null || echo "(none)")

echo "Installed: $local_ver"
echo "Latest tag on $remote/$default_branch: $latest_tag"
echo "Commits behind: $behind  |  ahead: $ahead"

# --- Up-to-date branch ------------------------------------------------------

if [ "$behind" -eq 0 ]; then
    extra=""
    if [ "$ahead" -gt 0 ]; then
        extra="\n\nNote: your local clone has $ahead commit(s) <i>ahead</i> of $remote/$default_branch — looks like a working tree."
    fi
    bot_raise_dialog "Bitcoin on Tails is up to date"
    zenity --info --title="Bitcoin on Tails is up to date" \
        --text="<b>Bitcoin on Tails is up to date.</b>\n\nInstalled: <tt>$local_ver</tt>\nLatest tag on $remote/$default_branch: <tt>$latest_tag</tt>$extra" \
        --width=520 "$ICON_ARG" --icon=bot128 2>/dev/null
    exit 0
fi

# --- Updates available — yad form with copyable commands -------------------
#
# Use window-bottom --button entries (not in-form FBTN fields) so clicking
# "Upgrade now" CLOSES this dialog with a distinct exit code. We then fire
# bot-update-now from the script AFTER yad exits — cleanly, without
# leaving a stale "Update available" window behind. The previous FBTN
# approach left the dialog open after firing.
#
# Exit code conventions:
#   42 — user clicked "Upgrade now"
#    0 — user clicked Close / dismissed
# (yad reserves 252 for window-close button [X] — treated same as Close.)

manual_cmd_clone='rm -rf ~/bot && git clone https://github.com/satscoffee/bitcoin-on-tails ~/bot && ~/bot/b'
manual_cmd_pull="cd $INSTALLED_BOT_DIR && git pull && ./b"
manual_cmd_verify="cd $INSTALLED_BOT_DIR && git tag -v $latest_tag"

bot_raise_dialog "Bitcoin on Tails — update available"
yad --form --columns=1 --width=640 --height=420 \
    --title="Bitcoin on Tails — update available" \
    --image="$ICON_FILE" --image-on-top \
    --field="<b>Update available.</b>:LBL" "" \
    --field="Installed:RO"               "$local_ver" \
    --field="Latest published tag:RO"    "$latest_tag" \
    --field="Commits behind $remote/$default_branch:RO" "$behind" \
    --field=":LBL" "Pick how you want to update. BoT will not update automatically — you have to choose." \
    --field="<b>Or copy and paste one of these manual commands instead:</b>:LBL" "" \
    --field="Fresh clone (replaces ~/bot):" "$manual_cmd_clone" \
    --field="In-place pull (working tree):" "$manual_cmd_pull" \
    --field="Verify tag signature first:"   "$manual_cmd_verify" \
    --field=":LBL" "Tip: click a field above, Ctrl+A to select all, then Ctrl+C to copy." \
    --button="Upgrade now!gtk-go-up:42" \
    --button="gtk-close:0" \
    "$ICON_ARG"
yad_rc=$?

# Fire bot-update-now ONLY if the user chose Upgrade. setsid fully detaches
# stdio + controlling terminal so bot-update-now (and the bot-menu it
# eventually spawns) can't be SIGHUP'd by anything in this process tree.
if [ "$yad_rc" = "42" ]; then
    setsid bot-update-now </dev/null >/dev/null 2>&1 &
fi

exit 0
